---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Icon from '../components/Icon.astro';
---
<Layout noindex={true}>
  <div class="pagina-carrito">
    <Breadcrumb items={[
      { text: "Inicio", href: "/" },
      { text: "Carrito" }
    ]} />

    <section class="carrito">
      <div class="container">
        <div class="carrito-header">
          <h1><Icon name="cart" size={28} /> Tu Carrito</h1>
        </div>

        <div class="carrito-content">
          <!-- Lista de Productos -->
          <div class="carrito-productos">
            <div id="carrito-lista"></div>
            <button id="vaciar-carrito" class="btn-vaciar">Vaciar carrito</button>
          </div>

          <!-- Resumen y Formulario -->
          <div class="carrito-sidebar">
            <div class="carrito-resumen">
              <h2>Resumen</h2>
              
              <!-- Campo de cupón -->
              <div class="coupon-section">
                <div class="coupon-input-group">
                  <input 
                    type="text" 
                    id="coupon-code" 
                    placeholder="Código de descuento"
                    class="coupon-input"
                  />
                  <button type="button" id="btn-aplicar-cupon" class="btn-aplicar-cupon">
                    Aplicar
                  </button>
                </div>
                <div id="coupon-message" class="coupon-message"></div>
                <div id="coupon-applied" class="coupon-applied" style="display: none;">
                  <span id="coupon-code-display"></span>
                  <button type="button" id="btn-remover-cupon" class="btn-remover-cupon">✕</button>
                </div>
              </div>
              
              <div class="resumen-item">
                <span>Subtotal:</span>
                <span id="carrito-total">$0</span>
              </div>
              
              <div class="resumen-item" id="descuento-item" style="display: none;">
                <span>Descuento:</span>
                <span id="descuento-amount" style="color: #28a745;">-$0</span>
              </div>
       
              <div class="resumen-item">
                <span>Envío:</span>
                <span id="envio-info">-</span>
              </div>
              <div class="resumen-total">
                <span>Total:</span>
                <span id="total">$0</span>
              </div>
            </div>

            <!-- Paso 1: Solo método de pago + Continuar -->
            <div id="formulario-paso1" class="formulario-carrito checkout-paso1">
              <div id="no-pagos-mensaje" class="no-pagos-mensaje" style="display: none; padding: 1rem; background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; margin-bottom: 1rem;">
                <p style="color: #856404; font-weight: 600; margin: 0;">No hay medios de pago habilitados</p>
                <p style="color: #856404; font-size: 0.9rem; margin: 0.5rem 0 0;">El administrador debe configurar Alias, CBU y titular en Configurar Pagos, o activar MercadoPago.</p>
              </div>
              <div id="formas-pago-wrap">
                <div class="form-group">
                  <label for="pago">Forma de pago</label>
                  <select id="pago">
                    <option value="transferencia_directa" selected>Transferencia</option>
                    <option value="tarjeta">Mercadopago o tarjeta - Mismo precio hasta en 3 cuotas</option>
                  </select>
                </div>
                <button type="button" id="btn-continuar-paso1" class="btn-continuar">Continuar con la compra</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Modal Paso 2: Datos personales -->
    <div id="modal-paso2" class="checkout-modal" style="display: none;">
      <div class="checkout-modal-overlay"></div>
      <div class="checkout-modal-content">
        <button type="button" class="checkout-modal-close" aria-label="Cerrar">×</button>
        <h2>Datos del comprador</h2>
        <form id="form-datos-personales">
          <div class="form-group">
            <label for="nombre">Nombre completo *</label>
            <input type="text" id="nombre" required />
          </div>
          <div class="form-group">
            <label for="telefono">Teléfono *</label>
            <input type="tel" id="telefono" required placeholder="Ej: 3794123456" />
            <small>Ingresa tu número de teléfono (sin guiones ni espacios)</small>
          </div>
          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" required placeholder="tu@email.com" />
          </div>
          <div class="form-group">
            <label for="aclaraciones">Aclaración del pedido</label>
            <textarea id="aclaraciones" rows="3" placeholder="Ej: Cambiar el texto por X, Que el título sea color rojo, etc."></textarea>
          </div>
          <div class="checkout-modal-actions">
            <button type="button" class="btn-modal-back" id="btn-back-paso2">Volver</button>
            <button type="button" class="btn-continuar" id="btn-continuar-paso2">Continuar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal Paso 3: Solo tipo de envío -->
    <div id="modal-paso3" class="checkout-modal" style="display: none;">
      <div class="checkout-modal-overlay"></div>
      <div class="checkout-modal-content">
        <button type="button" class="checkout-modal-close" aria-label="Cerrar">×</button>
        <h2>Tipo de envío</h2>
        <form id="form-tipo-envio">
          <div class="form-group">
            <label>Tipo de envío *</label>
            <div class="envio-options">
              <label class="envio-option">
                <input type="radio" name="envio" value="Corrientes Envio a Domicilio" required />
                <span class="envio-option-content">
                  <span class="envio-option-text">Envío a domicilio - Corrientes, Capital</span>
                </span>
              </label>
              <label class="envio-option">
                <input type="radio" name="envio" value="Corrientes Retiro en Sucursal" required checked />
                <span class="envio-option-content">
                  <span class="envio-option-text">Retiro por Pje. Alvarez 873 (Corrientes)</span>
                  <span class="envio-gratis">- Gratis</span>
                </span>
              </label>
              <label class="envio-option">
                <input type="radio" name="envio" value="Correo Argentino - Sucursal" required />
                <span class="envio-option-content">
                  <span class="envio-option-text">Correo Argentino - Envío a Sucursal</span>
                  <span class="envio-precio" data-precio-transferencia="6500">($8.100)</span>
                </span>
              </label>
              <label class="envio-option">
                <input type="radio" name="envio" value="Correo Argentino - Domicilio" required />
                <span class="envio-option-content">
                  <span class="envio-option-text">Correo Argentino - Envío a Domicilio</span>
                  <span class="envio-precio" data-precio-transferencia="8500">($10.600)</span>
                </span>
              </label>
            </div>
          </div>
          <div class="checkout-modal-actions">
            <button type="button" class="btn-modal-back" id="btn-back-paso3">Volver</button>
            <button type="button" class="btn-continuar" id="btn-continuar-paso3">Continuar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal Paso 3b: Datos de dirección (según tipo elegido) -->
    <div id="modal-paso3b" class="checkout-modal" style="display: none;">
      <div class="checkout-modal-overlay"></div>
      <div class="checkout-modal-content">
        <button type="button" class="checkout-modal-close" aria-label="Cerrar">×</button>
        <h2>Dirección de envío</h2>
        <form id="form-datos-envio">
          <div class="form-group" id="label-provincia" style="display: none;">
            <label for="provincia">Provincia *</label>
            <input type="text" id="provincia" />
          </div>
          <div class="form-group" id="label-sucursal" style="display: none;">
            <label for="sucursal">Sucursal de destino *</label>
            <input type="text" id="sucursal" />
          </div>
          <div class="form-group" id="label-localidad" style="display: none;">
            <label for="localidad">Localidad *</label>
            <input type="text" id="localidad" />
          </div>
          <div class="form-group" id="label-direccion" style="display: none;">
            <label for="direccion">Dirección *</label>
            <input type="text" id="direccion" placeholder="Ej: Av. 3 de Abril 1234" />
          </div>
          <div class="form-group" id="label-cp" style="display: none;">
            <label for="cp">Código Postal *</label>
            <input type="text" id="cp" />
          </div>
          <div class="form-group" id="label-observaciones" style="display: none;">
            <label for="observaciones">Observaciones</label>
            <textarea id="observaciones" rows="3" placeholder="Ej: Portón negro, mandar moto de 16 a 19hs"></textarea>
          </div>
          <div class="checkout-modal-actions">
            <button type="button" class="btn-modal-back" id="btn-back-paso3b">Volver</button>
            <button type="button" class="btn-continuar" id="btn-continuar-paso3b">Continuar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal Resumen final -->
    <div id="modal-resumen" class="checkout-modal" style="display: none;">
      <div class="checkout-modal-overlay"></div>
      <div class="checkout-modal-content checkout-resumen-content">
        <button type="button" class="checkout-modal-close" aria-label="Cerrar">×</button>
        <h2>Resumen del pedido</h2>
        <div id="resumen-contenido" class="resumen-pedido"></div>
        <div class="resumen-total">
          <span>Total a pagar:</span>
          <span id="resumen-total-display">$0</span>
        </div>
        <div class="checkout-modal-actions">
          <button type="button" class="btn-modal-back" id="btn-back-resumen">Volver</button>
          <button type="button" class="btn-finalizar" id="btn-finalizar" style="display: none;">
            <Icon name="credit-card" size={18} /> Pagar con MercadoPago
          </button>
          <button type="button" class="btn-finalizar-directa" id="btn-finalizar-directa" style="display: none;">
            <Icon name="check" size={18} /> Comprar
          </button>
        </div>
      </div>
    </div>

    <!-- Modal Paso 4: Transferencia - Datos bancarios + Comprobante -->
    <div id="modal-transferencia" class="checkout-modal" style="display: none;">
      <div class="checkout-modal-overlay"></div>
      <div class="checkout-modal-content">
        <button type="button" class="checkout-modal-close" aria-label="Cerrar">×</button>
        <h2>Datos para transferencia</h2>
        <div class="datos-bancarios">
          <div class="datos-transferencia">
            <p><strong>Alias:</strong> <span id="transfer-alias">-</span></p>
            <p id="transfer-cbu-row" style="display: none;"><strong>CBU:</strong> <span id="transfer-cbu">-</span></p>
            <p><strong>Titular:</strong> <span id="transfer-titular">-</span></p>
            <p><strong>Total a transferir:</strong> <span id="total-transferir">$0</span></p>
          </div>
          <div class="form-group">
            <label for="proof_image">Comprobante de pago *</label>
            <input type="file" id="proof_image" accept="image/jpeg,image/png,image/webp" style="display: none;" />
            <button type="button" id="btn-subir-comprobante" class="btn-subir-comprobante">
              <Icon name="paperclip" size={18} /> Subir comprobante de pago
            </button>
            <div id="proof-preview" style="display: none; margin-top: 0.5rem;">
              <img id="proof-preview-img" src="" alt="Vista previa" style="max-width: 200px; max-height: 200px; border-radius: 8px; border: 1px solid #ddd;" />
            </div>
          </div>
        </div>
        <div class="checkout-modal-actions">
          <button type="button" class="btn-modal-back" id="btn-back-transferencia">Volver</button>
          <button type="button" class="btn-finalizar-directa" id="btn-confirmar-transferencia">
            <Icon name="check" size={18} /> Confirmar pedido
          </button>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    @keyframes slideUp {
      from {
        transform: translateX(-50%) translateY(100%);
        opacity: 0;
      }
      to {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
      }
    }

    @keyframes slideDown {
      from {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
      }
      to {
        transform: translateX(-50%) translateY(100%);
        opacity: 0;
      }
    }

    /* Modales checkout */
    .checkout-modal {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 10000;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .checkout-modal-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      pointer-events: none;
    }
    .checkout-modal-close {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      width: 2rem;
      height: 2rem;
      padding: 0;
      border: none;
      background: transparent;
      color: #64748b;
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s, background 0.2s;
    }
    .checkout-modal-close:hover {
      color: #334155;
      background: #f1f5f9;
    }
    .checkout-modal-content {
      position: relative;
      background: #fff;
      border-radius: 12px;
      padding: 1rem;
      max-width: 600px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 10px 40px #0003;
    }
    @media (min-width: 769px) {
      .checkout-modal-content {
        padding: 2rem;
      }
    }
    .checkout-modal-content h2 {
      margin: 0 0 1.5rem 0;
      font-size: 1.35rem;
    }
    .checkout-modal-actions {
      display: flex;
      margin-top: 1.5rem;
      justify-content: space-between;
      width: 100%;
      flex-wrap: wrap;
      align-items: stretch;
    }
    .checkout-modal-actions .btn-modal-back {
      order: 1;
      width: auto;
      height: auto;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .checkout-modal-actions .btn-continuar,
    .checkout-modal-actions .btn-finalizar,
    .checkout-modal-actions .btn-finalizar-directa {
      order: 2;
      margin-left: auto;
      margin-top: 0;
      width: auto;
      min-width: 140px;
      min-height: 44px;
    }
    /* Coherencia botones carrito: Vaciar, Aplicar, Continuar con la compra */
    .pagina-carrito .btn-vaciar,
    .pagina-carrito #btn-continuar-paso1 {
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: 8px;
    }
    .pagina-carrito .btn-aplicar-cupon {
      padding: 0.75rem 1.25rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: 8px;
    }
    .pagina-carrito #formas-pago-wrap {
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }
    .pagina-carrito #btn-continuar-paso1 {
      width: 100%;
      margin-top: 1rem;
      text-align: center;
    }
    /* Botón principal "Continuar con la compra" y Continuar en modales: verde */
    .pagina-carrito #btn-continuar-paso1,
    .checkout-modal .btn-continuar {
      padding: 0.75rem 1.5rem;
      background: linear-gradient(135deg, #22c55e, #16a34a);
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
    }
    .pagina-carrito #btn-continuar-paso1:hover,
    .checkout-modal .btn-continuar:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
      background: linear-gradient(135deg, #16a34a, #15803d);
    }
    .btn-modal-back {
      padding: 0.875rem 1.5rem;
      background: #f1f5f9;
      color: #475569;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
      box-sizing: border-box;
    }
    .btn-modal-back:hover {
      background: #e2e8f0;
      color: #334155;
      border-color: #cbd5e1;
    }
    .resumen-pedido {
      margin-bottom: 1rem;
    }
    .resumen-seccion {
      margin-bottom: 0.75rem;
      font-size: 0.95rem;
    }
    .resumen-seccion ul {
      margin: 0.25rem 0 0 1rem;
      padding: 0;
    }
    .checkout-resumen-content .resumen-total {
      padding: 1rem 0;
      border-top: 2px solid var(--primary);
      font-size: 1.2rem;
      font-weight: 700;
    }
    /* Botones finalizar en modales: verde, estética consistente */
    .checkout-modal .btn-finalizar,
    .checkout-modal .btn-finalizar-directa {
      background: linear-gradient(135deg, #22c55e, #16a34a);
      color: white;
      padding: 0.875rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
    .checkout-modal .btn-finalizar:hover,
    .checkout-modal .btn-finalizar-directa:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
      background: linear-gradient(135deg, #16a34a, #15803d);
    }
    .checkout-modal .btn-subir-comprobante {
      background: linear-gradient(135deg, #22c55e, #16a34a);
      color: white;
      padding: 0.75rem 1.25rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
    }
    .checkout-modal .btn-subir-comprobante:hover {
      background: linear-gradient(135deg, #16a34a, #15803d);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
    }
    @media (max-width: 380px) {
      .checkout-modal .btn-modal-back,
      .checkout-modal .btn-continuar,
      .checkout-modal .btn-finalizar,
      .checkout-modal .btn-finalizar-directa,
      .checkout-modal .btn-subir-comprobante {
        font-size: 0.8rem;
      }
      .checkout-modal .btn-finalizar svg,
      .checkout-modal .btn-finalizar-directa svg {
        width: 16px !important;
        height: 16px !important;
      }
    }
  </style>

  <script is:inline>
    // Esperar a que cart.js se cargue y las funciones estén disponibles
    async function initCarrito() {
      // Verificar que las funciones estén disponibles
      if (typeof window.getCarrito === 'undefined' || typeof window.saveCarrito === 'undefined') {
        console.log('Esperando a que cart.js se cargue...');
        setTimeout(initCarrito, 100);
        return;
      }

      console.log('cart.js cargado correctamente');
      const getCarrito = window.getCarrito;
      const saveCarrito = window.saveCarrito;
      const updateCartCount = window.updateCartCount || (() => {});
      let hayMediosPago = false;

      // Cargar datos de transferencia desde la API (siempre fresco para reflejar cambios en Configurar pagos)
      async function cargarDatosTransferencia() {
        try {
          const res = await fetch('/api/shop.php');
          const data = await res.json();
          let shop = null;
          if (data.success && data.shop) {
            shop = data.shop;
            const cacheKey = 'shop_settings' + (window.__STORE_BASE || '');
            localStorage.setItem(cacheKey, JSON.stringify(shop));
            const discount = (shop.transfer_discount_percent ?? 20);
            window.__transferDiscountPercent = discount;
            window.__cardMultiplier = (discount > 0 && discount < 100) ? (1 / (1 - discount / 100)) : 1.25;
          }
          if (shop) {
            const aliasEl = document.getElementById('transfer-alias');
            const cbuEl = document.getElementById('transfer-cbu');
            const cbuRow = document.getElementById('transfer-cbu-row');
            const titularEl = document.getElementById('transfer-titular');
            const transferOk = !!(shop.transfer_alias && shop.transfer_cbu && shop.transfer_titular);
            const mpOk = !!shop.mercadopago_configured;
            hayMediosPago = transferOk || mpOk;

            const noPagosMsg = document.getElementById('no-pagos-mensaje');
            const formasPagoWrap = document.getElementById('formas-pago-wrap');
            if (!hayMediosPago) {
              if (noPagosMsg) noPagosMsg.style.display = 'block';
              if (formasPagoWrap) formasPagoWrap.style.display = 'none';
            } else {
              if (noPagosMsg) noPagosMsg.style.display = 'none';
              if (formasPagoWrap) formasPagoWrap.style.display = 'block';
              if (aliasEl) aliasEl.textContent = shop.transfer_alias || '-';
              if (titularEl) titularEl.textContent = shop.transfer_titular || '-';
              if (cbuEl && shop.transfer_cbu) {
                cbuEl.textContent = shop.transfer_cbu;
                if (cbuRow) cbuRow.style.display = 'block';
              }
              const pagoSelect = document.getElementById('pago');
              const totalTransferir = document.getElementById('total-transferir');
              if (!mpOk) {
                const optTarjeta = pagoSelect?.querySelector('option[value="tarjeta"]');
                if (optTarjeta) optTarjeta.remove();
                if (pagoSelect) pagoSelect.value = 'transferencia_directa';
                if (totalTransferir) totalTransferir.textContent = '$0';
              }
            }
          }
        } catch (e) { console.warn('No se pudieron cargar datos de transferencia:', e); }
      }

      const contenedor = document.querySelector("#carrito-lista");
      const totalEl = document.querySelector("#total");
      const envioInfoEl = document.querySelector("#envio-info");
      const carritoTotalEl = document.querySelector("#carrito-total");
      const finalizarBtn = document.querySelector("#btn-finalizar");
      const vaciarBtn = document.getElementById("vaciar-carrito");
      
      // Asegurar que el botón sea un button, no un link
      if (finalizarBtn && finalizarBtn.tagName === 'A') {
        finalizarBtn.style.display = 'none';
        console.error('El botón finalizar debe ser un <button>, no un <a>');
      }

      function actualizarFormularioEnvio() {
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const tipoEnvio = envioRadio ? envioRadio.value : '';
      const mostrar = id => document.getElementById(id).style.display = 'block';
      const ocultar = id => document.getElementById(id).style.display = 'none';

      ['label-provincia', 'label-direccion', 'label-sucursal', 'label-localidad', 'label-cp', 'label-observaciones']
        .forEach(ocultar);

      if (tipoEnvio === 'Corrientes Envio a Domicilio') {
        mostrar('label-direccion');
        mostrar('label-observaciones');
      } else if (tipoEnvio === 'Correo Argentino - Sucursal') {
        mostrar('label-provincia');
        mostrar('label-sucursal');
      } else if (tipoEnvio === 'Correo Argentino - Domicilio') {
        ['label-provincia', 'label-localidad', 'label-cp', 'label-direccion', 'label-observaciones']
          .forEach(mostrar);
      }
    }

    // Función para actualizar precios de envío según método de pago
    function actualizarPreciosEnvio() {
      const pago = document.getElementById('pago')?.value || '';
      const isTransferencia = (pago === 'transferencia_directa');
      const mult = window.__cardMultiplier ?? 1.25;
      
      const precioElements = document.querySelectorAll('.envio-precio');
      precioElements.forEach(el => {
        const precioTransferencia = el.getAttribute('data-precio-transferencia');
        if (!precioTransferencia) return;
        const transferNum = parseInt(precioTransferencia, 10) || 0;
        const precioTarjeta = Math.round((transferNum * mult) / 100) * 100;
        const precioMostrar = isTransferencia ? transferNum : precioTarjeta;
        const precioFormateado = '$' + precioMostrar.toLocaleString('es-AR');
        el.textContent = `(${precioFormateado})`;
      });
    }

    // Función para extraer el valor numérico del precio (remueve $, puntos, comas, etc.)
    function extractPriceValue(priceString) {
      if (!priceString) return 0;
      // Remover todos los caracteres no numéricos (incluyendo $, puntos, comas, espacios)
      const cleaned = priceString.replace(/[^0-9]/g, '');
      return parseInt(cleaned, 10) || 0;
    }

    // Función para calcular precio de tarjeta desde precio de transferencia (redondeado al 100)
    function calculateCardPriceFromTransfer(transferPrice) {
      const mult = window.__cardMultiplier ?? 1.25;
      return Math.round((transferPrice * mult) / 100) * 100;
    }


        // Aplicar descuento de cupón si existe (revalidar primero para obtener el descuento actualizado)
        const couponData = JSON.parse(localStorage.getItem('applied_coupon' + (window.__STORE_BASE || '')) || 'null');
        let descuentoCupon = 0;
        if (couponData && couponData.valid) {
          // Revalidar para obtener el descuento actualizado con el carrito actual
          const revalidationResult = await revalidarCupon(couponData.coupon.code, totalCarrito, carrito);
          if (revalidationResult && revalidationResult.valid) {
            descuentoCupon = revalidationResult.discount || 0;
          } else {
            // Si el cupón ya no es válido, no aplicar descuento
            descuentoCupon = 0;
          }
        }
        
        let totalFinal = totalCarrito + envioCosto - descuentoCupon;
        
        // El total no puede ser negativo
        if (totalFinal < 0) {
          totalFinal = 0;
        }
        
        // Preparar FormData
        const formData = new FormData();
        formData.append('proof_image', proofFile);
        formData.append('nombre', nombre);
        formData.append('telefono', telefono);
        formData.append('email', document.getElementById('email')?.value || '');
        formData.append('total_amount', totalFinal);
        formData.append('items', JSON.stringify(carrito.map(item => ({
          name: item.name,
          slug: item.slug,
          price: item.price,
          cantidad: item.cantidad
        }))));
        formData.append('shipping', JSON.stringify({
          type: envio,
          address: document.getElementById('direccion')?.value || '',
          province: document.getElementById('provincia')?.value || '',
          locality: document.getElementById('localidad')?.value || '',
          postal_code: document.getElementById('cp')?.value || '',
          sucursal: document.getElementById('sucursal')?.value || '',
          observations: document.getElementById('observaciones')?.value || ''
        }));
        formData.append('notes', document.getElementById('aclaraciones')?.value || '');
        if (couponData && couponData.valid && couponData.coupon) {
          formData.append('coupon_code', couponData.coupon.code);
          formData.append('discount_amount', descuentoCupon);
        }
        
        const response = await fetch('/api/orders/create-direct-transfer.php', {
          method: 'POST',
          body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
          // Limpiar carrito
          saveCarrito([]);
          // Redirigir a página de pendiente (transferencia directa requiere confirmación)
          const orderId = data.order_id ? `?order_id=${data.order_id}` : '';
          window.location.href = (window.__STORE_BASE||'') + `/carrito/pendiente${orderId}`;
        } else {
          alert('Error al crear el pedido: ' + (data.error || 'Error desconocido'));
          btnConfirmar.disabled = false;
          btnConfirmar.textContent = 'Confirmar pedido';
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error de conexión. Por favor, intenta nuevamente.');
        btnConfirmar.disabled = false;
        btnConfirmar.textContent = 'Confirmar pedido';
      }
    });
    
    // Prevenir submit de formularios en modales
    document.getElementById('form-datos-personales')?.addEventListener('submit', (e) => { e.preventDefault(); validarPaso2() && (hideAllModals(), openModalPaso3()); });
    document.getElementById('form-datos-envio')?.addEventListener('submit', (e) => { e.preventDefault(); validarPaso3b() && (hideAllModals(), openModalResumen()); });

    // Obtener stock disponible de un producto (desde item o API)
    async function obtenerStockDisponible(item) {
      if (item.stock != null && item.stock !== undefined && item.stock !== '') {
        return parseInt(item.stock, 10);
      }
      try {
        const res = await fetch(`/api/products.php?slug=${encodeURIComponent(item.slug)}`);
        const data = await res.json();
        if (data.success && data.product && data.product.stock != null) {
          return parseInt(data.product.stock, 10);
        }
      } catch (err) { console.warn('Error al obtener stock:', err); }
      return null; // null = ilimitado
    }

    document.addEventListener("click", async (e) => {
      const slug = e.target.dataset.slug;
      if (!slug) return;

      let carrito = getCarrito();
      const index = carrito.findIndex(p => p.slug === slug);
      if (index === -1) return;

      const item = carrito[index];

      if (e.target.classList.contains("btn-remove")) {
        carrito.splice(index, 1);
      } else if (e.target.classList.contains("mas")) {
        const stockDisponible = await obtenerStockDisponible(item);
        if (stockDisponible !== null && item.cantidad >= stockDisponible) {
          mostrarNotificacionCarrito(`Solo contamos con ${stockDisponible} unidad${stockDisponible === 1 ? '' : 'es'} de este producto`, 'info');
          return;
        }
        item.cantidad++;
        if (stockDisponible !== null) item.stock = stockDisponible;
      } else if (e.target.classList.contains("menos")) {
        // Usar min_quantity del item si existe, sino usar lógica antigua como fallback
        const minCantidad = item.min_quantity || (item.categoria === "souvenirs" ? 10 : 1);

        if (item.cantidad > minCantidad) {
          item.cantidad--;
        } else if (!item.min_quantity) {
          // Solo eliminar si no tiene min_quantity (comportamiento antiguo)
          carrito.splice(index, 1);
        }
        // Si tiene min_quantity, no se puede reducir por debajo ni eliminar
      }

      saveCarrito(carrito);
      
      // Revalidar cupón si existe antes de renderizar
      const couponData = JSON.parse(localStorage.getItem('applied_coupon' + (window.__STORE_BASE || '')) || 'null');
      if (couponData && couponData.valid) {
        // Calcular total para revalidación (precio base de transferencia)
        let totalCarrito = 0;
        carrito.forEach((item) => {
          const transferPriceValue = extractPriceValue(item.price);
          totalCarrito += transferPriceValue * item.cantidad;
        });
        const pago = document.getElementById('pago')?.value || '';
        // Si es tarjeta, aplicar 25% más para la validación del cupón
        if (pago === 'tarjeta') {
          const mult = window.__cardMultiplier ?? 1.25;
          totalCarrito = Math.round((totalCarrito * mult) / 100) * 100;
        }
        // Revalidar asíncronamente y actualizar descuento
        revalidarCupon(couponData.coupon.code, totalCarrito, carrito).then(result => {
          if (!result || !result.valid) {
            localStorage.removeItem('applied_coupon' + (window.__STORE_BASE || ''));
            ocultarCuponAplicado();
            mostrarMensajeCupon('El cupón ya no es válido para los productos en tu carrito', 'error');
          } else {
            // Actualizar el descuento en localStorage con el nuevo valor
            couponData.discount = result.discount || 0;
            localStorage.setItem('applied_coupon' + (window.__STORE_BASE || ''), JSON.stringify(couponData));
          }
          renderCarrito();
        });
      } else {
        renderCarrito();
      }
    });

    vaciarBtn.addEventListener("click", () => {
      if (confirm("¿Seguro que querés vaciar el carrito?")) {
        saveCarrito([]);
        // Remover cupón si se vacía el carrito
        localStorage.removeItem('applied_coupon' + (window.__STORE_BASE || ''));
        ocultarCuponAplicado();
        mostrarMensajeCupon('', '');
        renderCarrito();
      }
    });

    // Función para aplicar cupón
    async function aplicarCupon() {
      const code = document.getElementById('coupon-code')?.value.trim().toUpperCase();
      if (!code) {
        mostrarMensajeCupon('Ingresa un código de cupón', 'error');
        return;
      }
      
      const carrito = getCarrito();
      if (carrito.length === 0) {
        mostrarMensajeCupon('El carrito está vacío', 'error');
        return;
      }
      
      // Calcular total del carrito (precio base de transferencia)
      let totalCarrito = 0;
      carrito.forEach((item) => {
        const transferPriceValue = extractPriceValue(item.price);
        totalCarrito += transferPriceValue * item.cantidad;
      });
      
      const pago = document.getElementById('pago')?.value || '';
      // Si es tarjeta, aplicar 25% más para la validación del cupón
      if (pago === 'tarjeta') {
        const mult = window.__cardMultiplier ?? 1.25;
        totalCarrito = Math.round((totalCarrito * mult) / 100) * 100;
      }
      
      // Preparar items para validación
      const items = carrito.map(item => ({
        slug: item.slug,
        categoria: item.categoria,
        id: item.slug // Usar slug como ID para validación
      }));
      
      try {
        const response = await fetch('/api/coupons/validate.php', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            code: code,
            total_amount: totalCarrito,
            items: items
          })
        });
        
        const data = await response.json();
        
        if (data.success && data.valid) {
          // Guardar cupón aplicado
          localStorage.setItem('applied_coupon' + (window.__STORE_BASE || ''), JSON.stringify(data));
          mostrarCuponAplicado(data.coupon.code, data.discount);
          mostrarMensajeCupon(data.message, 'success');
          renderCarrito(); // Recalcular totales
        } else {
          mostrarMensajeCupon(data.message || 'Código de cupón no válido', 'error');
          localStorage.removeItem('applied_coupon' + (window.__STORE_BASE || ''));
          ocultarCuponAplicado();
        }
      } catch (error) {
        console.error('Error al validar cupón:', error);
        mostrarMensajeCupon('Error al validar el cupón. Por favor, intenta nuevamente.', 'error');
      }
    }
    
    // Función para revalidar cupón con el carrito actual
    async function revalidarCupon(code, totalAmount, carrito) {
      if (!code || !carrito || carrito.length === 0) {
        return { valid: false, discount: 0 };
      }
      
      // Preparar items para validación
      const items = carrito.map(item => ({
        slug: item.slug,
        categoria: item.categoria,
        id: item.slug
      }));
      
      try {
        const response = await fetch('/api/coupons/validate.php', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            code: code,
            total_amount: totalAmount,
            items: items
          })
        });
        
        const data = await response.json();
        if (data.success && data.valid) {
          return { valid: true, discount: data.discount || 0 };
        } else {
          return { valid: false, discount: 0 };
        }
      } catch (error) {
        console.error('Error al revalidar cupón:', error);
        return { valid: false, discount: 0 };
      }
    }
    
    // Función para remover cupón
    function removerCupon() {
      localStorage.removeItem('applied_coupon' + (window.__STORE_BASE || ''));
      ocultarCuponAplicado();
      mostrarMensajeCupon('', '');
      const couponInput = document.getElementById('coupon-code');
      if (couponInput) couponInput.value = '';
      renderCarrito(); // Recalcular totales
    }
    
    // Función para mostrar mensaje de cupón
    function mostrarMensajeCupon(message, type) {
      const messageEl = document.getElementById('coupon-message');
      if (!messageEl) return;
      
      if (!message) {
        messageEl.textContent = '';
        messageEl.className = 'coupon-message';
        return;
      }
      
      messageEl.textContent = message;
      messageEl.className = `coupon-message ${type}`;
    }
    
    // Función para mostrar cupón aplicado
    function mostrarCuponAplicado(code, discount) {
      const appliedEl = document.getElementById('coupon-applied');
      const codeDisplay = document.getElementById('coupon-code-display');
      if (appliedEl) appliedEl.style.display = 'flex';
      if (codeDisplay) codeDisplay.textContent = `Cupón: ${code} (-$${discount.toLocaleString('es-AR')})`;
    }
    
    // Función para ocultar cupón aplicado
    function ocultarCuponAplicado() {
      const appliedEl = document.getElementById('coupon-applied');
      if (appliedEl) appliedEl.style.display = 'none';
    }
    
    // Event listeners para cupón
    document.addEventListener('click', (e) => {
      if (e.target.id === 'btn-aplicar-cupon' || e.target.closest('#btn-aplicar-cupon')) {
        e.preventDefault();
        e.stopPropagation();
        aplicarCupon();
      }
      if (e.target.id === 'btn-remover-cupon' || e.target.closest('#btn-remover-cupon')) {
        e.preventDefault();
        e.stopPropagation();
        removerCupon();
      }
    });
    
    // Aplicar cupón con Enter (usar delegación de eventos para que funcione siempre)
    document.addEventListener('keypress', (e) => {
      if (e.target.id === 'coupon-code' && e.key === 'Enter') {
        e.preventDefault();
        aplicarCupon();
      }
    });
    
    // Cargar cupón aplicado al iniciar (después de que el DOM esté listo)
    setTimeout(() => {
      const couponData = JSON.parse(localStorage.getItem('applied_coupon' + (window.__STORE_BASE || '')) || 'null');
      if (couponData && couponData.valid) {
        mostrarCuponAplicado(couponData.coupon.code, couponData.discount);
      }
    }, 100);

    document.getElementById("form-datos")?.addEventListener("input", renderCarrito);
    
    // Event listener para método de pago (actualizar precios de envío)
    const pagoSelect = document.getElementById("pago");
    if (pagoSelect) {
      pagoSelect.addEventListener("change", () => {
        actualizarPreciosEnvio();
        renderCarrito();
      });
    }
    
    // Event listeners para radio buttons de envío
    document.querySelectorAll('input[name="envio"]').forEach(radio => {
      radio.addEventListener("change", () => {
        actualizarFormularioEnvio();
        renderCarrito();
      });
    });

    // === FLUJO DE CHECKOUT POR PASOS ===
    function showModal(id) {
      document.body.style.overflow = 'hidden';
      document.querySelectorAll('.checkout-modal').forEach(m => m.style.display = 'none');
      const modal = document.getElementById(id);
      if (modal) modal.style.display = 'flex';
    }
    function hideAllModals() {
      document.body.style.overflow = '';
      document.querySelectorAll('.checkout-modal').forEach(m => m.style.display = 'none');
    }
    function openModalPaso2() {
      showModal('modal-paso2');
    }
    function openModalPaso3() {
      showModal('modal-paso3');
    }
    function openModalPaso3b() {
      actualizarFormularioEnvio();
      showModal('modal-paso3b');
    }
    function openModalResumen() {
      const pago = document.getElementById('pago')?.value || '';
      const isTransferencia = (pago === 'transferencia_directa');
      const btnFinalizar = document.getElementById('btn-finalizar');
      const btnFinalizarDirecta = document.getElementById('btn-finalizar-directa');
      if (btnFinalizar) btnFinalizar.style.display = isTransferencia ? 'none' : 'inline-block';
      if (btnFinalizarDirecta) btnFinalizarDirecta.style.display = isTransferencia ? 'inline-block' : 'none';
      llenarResumen();
      showModal('modal-resumen');
    }
    function openModalTransferencia() {
      const totalTransferir = document.getElementById('total-transferir');
      const totalFinal = calcularTotalFinal();
      if (totalTransferir) totalTransferir.textContent = `$${totalFinal.toLocaleString('es-AR')}`;
      hideAllModals();
      showModal('modal-transferencia');
      setupProofImageChangeHandler();
    }
    function calcularTotalFinal() {
      const carrito = getCarrito();
      const pago = document.getElementById('pago')?.value || '';
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const envio = envioRadio ? envioRadio.value : '';
      let totalCarrito = 0;
      carrito.forEach(item => {
        totalCarrito += extractPriceValue(item.price) * item.cantidad;
      });
      let envioCosto = 0;
      if (envio.includes('Correo Argentino - Sucursal')) envioCosto = 6500;
      else if (envio.includes('Correo Argentino - Domicilio')) envioCosto = 8500;
      const isTarjeta = (pago === 'tarjeta');
      const mult = window.__cardMultiplier ?? 1.25;
      if (isTarjeta) {
        totalCarrito = Math.round((totalCarrito * mult) / 100) * 100;
        envioCosto = envioCosto > 0 ? Math.round((envioCosto * mult) / 100) * 100 : 0;
      }
      const couponData = JSON.parse(localStorage.getItem('applied_coupon' + (window.__STORE_BASE || '')) || 'null');
      let descuento = 0;
      if (couponData && couponData.valid) descuento = couponData.discount || 0;
      return Math.max(0, totalCarrito + envioCosto - descuento);
    }
    function llenarResumen() {
      const cont = document.getElementById('resumen-contenido');
      const totalDisplay = document.getElementById('resumen-total-display');
      if (!cont) return;
      const get = id => document.getElementById(id)?.value || '';
      const nombre = get('nombre');
      const telefono = get('telefono');
      const email = get('email');
      const aclaraciones = get('aclaraciones');
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const envio = envioRadio ? envioRadio.value : '';
      const pago = document.getElementById('pago')?.value || '';
      const totalFinal = calcularTotalFinal();
      let envioDetalle = '';
      if (envio === 'Corrientes Envio a Domicilio') {
        envioDetalle = get('direccion');
        if (get('observaciones')) envioDetalle += `. Obs: ${get('observaciones')}`;
      } else if (envio === 'Correo Argentino - Sucursal') envioDetalle = `Provincia: ${get('provincia')}, Sucursal: ${get('sucursal')}`;
      else if (envio === 'Correo Argentino - Domicilio') {
        envioDetalle = `${get('provincia')}, ${get('localidad')}, ${get('direccion')}, CP ${get('cp')}`;
        if (get('observaciones')) envioDetalle += `. Obs: ${get('observaciones')}`;
      } else if (envio === 'Corrientes Retiro en Sucursal') envioDetalle = 'Retiro en sucursal';
      const carrito = getCarrito();
      cont.innerHTML = `
        <div class="resumen-seccion"><strong>Datos:</strong> ${nombre} | ${telefono} | ${email}</div>
        ${aclaraciones ? `<div class="resumen-seccion"><strong>Aclaraciones:</strong> ${aclaraciones}</div>` : ''}
        <div class="resumen-seccion"><strong>Envío:</strong> ${envio}${envioDetalle ? ' - ' + envioDetalle : ''}</div>
        <div class="resumen-seccion"><strong>Productos:</strong><ul>${carrito.map(p => `<li>${p.name} x${p.cantidad}</li>`).join('')}</ul></div>
      `;
      if (totalDisplay) totalDisplay.textContent = `$${totalFinal.toLocaleString('es-AR')}`;
    }
    function validarPaso2() {
      const nombre = document.getElementById('nombre')?.value?.trim();
      const telefono = document.getElementById('telefono')?.value?.trim();
      const email = document.getElementById('email')?.value?.trim();
      if (!nombre) { alert('Por favor, completa tu nombre'); return false; }
      if (!telefono) { alert('Por favor, completa tu teléfono'); return false; }
      if (!email) { alert('Por favor, completa tu email'); return false; }
      return true;
    }
    function validarPaso3b() {
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const envio = envioRadio ? envioRadio.value : '';
      if (envio === 'Correo Argentino - Domicilio') {
        const provincia = document.getElementById('provincia')?.value?.trim();
        const localidad = document.getElementById('localidad')?.value?.trim();
        const direccion = document.getElementById('direccion')?.value?.trim();
        const cp = document.getElementById('cp')?.value?.trim();
        if (!provincia || !localidad || !direccion || !cp) {
          alert('Por favor, completa Provincia, Localidad, Dirección y Código Postal');
          return false;
        }
      } else if (envio === 'Correo Argentino - Sucursal') {
        const provincia = document.getElementById('provincia')?.value?.trim();
        const sucursal = document.getElementById('sucursal')?.value?.trim();
        if (!provincia || !sucursal) {
          alert('Por favor, completa Provincia y Sucursal de destino');
          return false;
        }
      } else if (envio === 'Corrientes Envio a Domicilio') {
        const direccion = document.getElementById('direccion')?.value?.trim();
        if (!direccion) { alert('Por favor, completa la dirección'); return false; }
      }
      return true;
    }
    document.getElementById('btn-continuar-paso1')?.addEventListener('click', () => openModalPaso2());
    document.getElementById('btn-continuar-paso2')?.addEventListener('click', () => {
      if (!validarPaso2()) return;
      hideAllModals();
      openModalPaso3();
    });
    document.getElementById('btn-back-paso2')?.addEventListener('click', () => hideAllModals());
    document.getElementById('btn-continuar-paso3')?.addEventListener('click', () => {
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const envio = envioRadio ? envioRadio.value : '';
      hideAllModals();
      if (envio === 'Corrientes Retiro en Sucursal') {
        openModalResumen();
      } else {
        openModalPaso3b();
      }
    });
    document.getElementById('btn-continuar-paso3b')?.addEventListener('click', () => {
      if (!validarPaso3b()) return;
      hideAllModals();
      openModalResumen();
    });
    document.getElementById('btn-back-paso3')?.addEventListener('click', () => {
      hideAllModals();
      openModalPaso2();
    });
    document.getElementById('btn-back-paso3b')?.addEventListener('click', () => {
      hideAllModals();
      openModalPaso3();
    });
    document.getElementById('btn-back-resumen')?.addEventListener('click', () => {
      hideAllModals();
      const envioRadio = document.querySelector('input[name="envio"]:checked');
      const envio = envioRadio ? envioRadio.value : '';
      if (envio === 'Corrientes Retiro en Sucursal') {
        openModalPaso3();
      } else {
        openModalPaso3b();
      }
    });
    document.getElementById('btn-back-transferencia')?.addEventListener('click', () => {
      hideAllModals();
      openModalResumen();
    });
    document.querySelectorAll('.checkout-modal-close').forEach(btn => {
      btn.addEventListener('click', () => hideAllModals());
    });
    document.getElementById('btn-finalizar-directa')?.addEventListener('click', (e) => {
      e.preventDefault();
      const pago = document.getElementById('pago')?.value || '';
      if (pago === 'transferencia_directa') {
        hideAllModals();
        openModalTransferencia();
      }
    });

      actualizarFormularioEnvio();
      actualizarPreciosEnvio();
      await cargarDatosTransferencia();
      renderCarrito();
    }

    // Inicializar cuando el DOM esté listo
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => initCarrito());
    } else {
      initCarrito();
    }
  </script>


</Layout>
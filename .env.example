# ============================================
# CONFIGURACIÓN DE ENTORNO - Somos Tiendi
# ============================================
# Copia este archivo como .env y rellena los valores

# Base de datos de la PLATAFORMA (platform_users, stores, store_members, shop_settings)
# En hosting compartido suele ser el mismo que DB_NAME, ej: u161673556_tiendamasha
PLATFORM_DB_HOST=localhost
PLATFORM_DB_NAME=u161673556_tiendamasha
PLATFORM_DB_USER=root
PLATFORM_DB_PASS=

# Base de datos de tienda individual (solo se usa en admin/)
DB_HOST=localhost
DB_NAME=lume_catalogo
DB_USER=root
DB_PASS=

# MercadoPago (tiendas - productos)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_TEST_MODE=true

# MercadoPago PLATAFORMA (cobro de membresías - cuenta Somos Tiendi)
PLATFORM_MP_ACCESS_TOKEN=
PLATFORM_MP_PUBLIC_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
